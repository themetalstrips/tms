RewriteEngine On

# Redirect /index or /index.html to / (the root)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/index(\.html)? [NC]
RewriteRule ^ %{ENV:PROTO}://%{HTTP_HOST}/ [R=301,L]

# Browser Redirect: force removal of .html extension from other pages
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.html [NC]
RewriteRule ^ %1 [R=301,L]

# Internal Rewrite: silently serve .html files if they exist
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*?)/?$ $1.html [L]
